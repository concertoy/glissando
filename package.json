{
  "name": "glissando",
  "version": "0.1.0",
  "description": "Component-based slide decks for coding agents — native editable PPTX output",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "./build.sh",
    "check": "tsc --noEmit",
    "test": "npx tsx scripts/test-examples.ts",
    "test:unit": "vitest run",
    "init": "npx tsx scripts/init.ts",
    "render": "npx tsx scripts/render-slide.ts",
    "docs:dev": "cd docs && npx mintlify dev"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mathjax-full": "^3.2.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
